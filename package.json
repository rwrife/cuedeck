{
  "name": "cuedeck",
  "version": "0.1.0",
  "description": "Demo cue cards with instant clipboard snippets — a desktop teleprompter for software demos.",
  "main": "./out/main/index.js",
  "author": "rwrife",
  "license": "MIT",
  "type": "module",
  "bin": {
    "cuedeck": "./out/cli/index.js",
    "cuedeck-mcp": "./out/mcp/index.js"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build && npm run build:cli && npm run build:mcp",
    "build:cli": "node scripts/build-cli.mjs",
    "build:mcp": "node scripts/build-mcp.mjs",
    "cli": "node scripts/build-cli.mjs && node ./out/cli/index.js",
    "mcp": "node scripts/build-mcp.mjs && node ./out/mcp/index.js",
    "preview": "electron-vite preview",
    "start": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "icons": "node scripts/gen-placeholder-icon.mjs",
    "gen:examples": "node scripts/gen-examples.mjs",
    "package": "electron-vite build && electron-builder --publish never",
    "package:dir": "electron-vite build && electron-builder --dir --publish never",
    "package:linux": "electron-vite build && electron-builder --linux --publish never",
    "package:win": "electron-vite build && electron-builder --win --publish never",
    "package:mac": "electron-vite build && electron-builder --mac --publish never"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3",
    "zustand": "^4.5.5"
  },
  "build": {
    "appId": "com.rwrife.cuedeck",
    "productName": "CueDeck",
    "copyright": "Copyright © 2026 rwrife",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "out/**",
      "package.json",
      "!**/*.map",
      "!**/*.ts",
      "!**/*.tsx"
    ],
    "asar": true,
    "electronLanguages": [
      "en-US"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.png"
    },
    "dmg": {
      "title": "${productName} ${version}"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility",
      "synopsis": "Demo cue cards with instant clipboard snippets",
      "description": "A desktop teleprompter for software demos — cue cards with one-click clipboard snippets.",
      "maintainer": "rwrife",
      "icon": "build/icon.png"
    }
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@vitejs/plugin-react": "^4.3.4",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "autoprefixer": "^10.4.20",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "esbuild": "^0.21.5",
    "eslint": "^8.57.1",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^4.6.2",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.2",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  }
}
